<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.valdes.trabajo.asistente.binderjobs.ui.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_webView"
            app:destination="@id/navigation_webview" />
    </fragment>

    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="com.valdes.trabajo.asistente.binderjobs.ui.dashboard.DashboardFragment"
        android:label="@string/title_dashboard"
        tools:layout="@layout/fragment_dashboard" />

    <fragment
        android:id="@+id/navigation_webview"
        android:name="com.valdes.trabajo.asistente.binderjobs.ui.web.JobWebViewFragment"
        android:label="Oferta"
        tools:layout="@layout/fragment_job_webview" />
</navigation>